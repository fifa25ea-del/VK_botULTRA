from vk_api import VkApi
from vk_api.longpoll import VkLongPoll, VkEventType

from config import TOKEN
from vk.handlers import handle

from storage.session import get_session, add_favorite
from services.search import find_part
from vk.navigation import next_item, prev_item
from vk.cards import send_card


vk_session = VkApi(token=TOKEN)
vk = vk_session.get_api()
longpoll = VkLongPoll(vk_session)


def run_bot():
    for event in longpoll.listen():
        if event.type == VkEventType.MESSAGE_NEW and event.to_me:
            user_id = event.user_id
            text = event.text

            handle_message(vk, user_id, text, parts_db=[])


def handle_message(vk, user_id, text, parts_db):
    session = get_session(user_id)

    # ⬅️➡️ навигация
    if text == "⬅️":
        prev_item(vk, user_id)
        return

    if text == "➡️":
        next_item(vk, user_id)
        return

    # ❤️ избранное
    if text == "❤️":
        add_favorite(user_id)
        vk.messages.send(
            user_id=user_id,
            message="Добавлено в избранное ❤️",
            random_id=0
        )
        return

    # 📞 менеджер
    if text == "📞 Менеджер":
        vk.messages.send(
            user_id=user_id,
            message="📞 Напишите менеджеру: https://vk.me/your_group",
            random_id=0
        )
        return

    # 🔍 поиск
    results = find_part(text, parts_db)

    if not results:
        vk.messages.send(
            user_id=user_id,
            message="❌ Ничего не найдено",
            random_id=0
        )
        return

    session["results"] = results
    session["index"] = 0

    send_card(vk, user_id, results[0], 0, len(results))
