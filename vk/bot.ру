from storage.session import get_session, add_favorite
from vk_api import VkApi
from vk_api.longpoll import VkLongPoll, VkEventType
from config import TOKEN
from vk.handlers import handle

vk_session = VkApi(token=TOKEN)
longpoll = VkLongPoll(vk_session)

def run_bot():
    for event in longpoll.listen():
        if event.type == VkEventType.MESSAGE_NEW and event.to_me:
            handle(event)
def handle_message(vk, user_id, text, parts_db):
if text == "📞 Менеджер":
    vk.messages.send(
        user_id=user_id,
        message="📞 Напишите менеджеру: https://vk.me/your_group",
        random_id=0
    )
    return
